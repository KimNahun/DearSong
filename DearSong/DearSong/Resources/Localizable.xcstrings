{
  "sourceLanguage" : "ko",
  "strings" : {
    "%@, %@" : {
      "comment" : "A button that lists a song with its title and artist name.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ko" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@, %2$@"
          }
        }
      }
    },
    "%@: %@" : {
      "comment" : "Accessibility label for the year picker. The argument is the string “screen.entry.year_label”.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ko" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@: %2$@"
          }
        }
      }
    },
    "%@: %@, %@" : {
      "comment" : "A label describing the currently selected song and artist. The argument is the string “action.selected”.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ko" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@: %2$@, %3$@"
          }
        }
      }
    },
    "%@%@" : {
      "comment" : "An accessibility label that combines the prefix \"timeline.location_prefix\" with the actual location string. The argument is the string “timeline.location_prefix”.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ko" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@%2$@"
          }
        }
      }
    },
    "%lld/1000" : {
      "comment" : "A text displaying the number of characters in the entry text, with a maximum of 1000 characters allowed.",
      "isCommentAutoGenerated" : true
    },
