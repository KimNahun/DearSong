    "prompt.firstMoment": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 곡을 처음 들으신 순간은 어떠셨나요?"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "How did it feel when you first heard this song?"
          }
        }
      }
    },
    "prompt.scene": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "그때 어디에 계셨고, 누구와 함께였나요?"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Where were you, and who were you with?"
          }
        }
      }
    },
    "prompt.feelingNow": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "지금 이 곡을 들으시면 어떤 감정이 드시나요?"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "What do you feel when you listen to it now?"
          }
        }
      }
    },
    "prompt.message": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 곡에게 남기고 싶은 한 줄이 있다면 적어주세요."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "If you'd leave one line for this song, what would it be?"
          }
        }
      }
    },
    "screen.signin.tagline": {
      "localizations": {
        "ko": {
